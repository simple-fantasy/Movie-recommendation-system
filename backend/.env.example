# Flask配置
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string-at-least-16-chars
DEBUG=True

# 数据库配置 (支持 mysql+pymysql / sqlite / postgresql)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/movie_rec?charset=utf8mb4

# TMDB API配置 (从 https://www.themoviedb.org/settings/api 获取)
TMDB_API_KEY=your_tmdb_api_key_here

# 推荐系统参数
ITEMCF_TOPK=50
NCF_EMBEDDING_DIM=32
NCF_HIDDEN_DIM=64
NCF_LR=0.001
NCF_BATCH_SIZE=256
NCF_EPOCHS=20

# 缓存配置
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

# 限流配置（生产环境建议开启）
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
